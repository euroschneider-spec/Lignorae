generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  EN
  DE
  RO
}

model Piece {
  id               String   @id @default(cuid())

  title            String
  collection       String
  slug             String   @unique

  status           String

  year             String?
  material         String?
  atelier          String?

  shortDescription String
  story            String?

  image            String
  detailImage      String?

  priceCents       Int?
  currency         String   @default("EUR")
  isPurchasable    Boolean  @default(false)

  translations     PieceTranslation[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PieceTranslation {
  id               String   @id @default(cuid())

  pieceId          String
  piece            Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  locale           Locale

  title            String
  collection       String
  shortDescription String
  story            String?
  material         String?
  atelier          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([pieceId, locale])
}

model JournalPost {
  id           String   @id @default(cuid())

  title        String
  slug         String   @unique

  excerpt      String
  content      String

  coverImage   String?

  published    Boolean  @default(false)

  translations JournalPostTranslation[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model JournalPostTranslation {
  id            String      @id @default(cuid())

  journalPostId String
  journalPost   JournalPost @relation(fields: [journalPostId], references: [id], onDelete: Cascade)

  locale        Locale

  title         String
  excerpt       String
  content       String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([journalPostId, locale])
}
